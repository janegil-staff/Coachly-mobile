{
  "expo": {
    "name": "Coachly",
    "slug": "coachly",
    "extra": {
      "apiUrl": "https://goldfish-app-8zz97.ondigitalocean.app"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/coachly-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qupda.coachly",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.qup.coachly",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/coachly-logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.ico"
    },
    "plugins": ["expo-localization", "expo-secure-store"]
  }
}
